    ])

if MODULE_MEANING_LLM_ENABLED:
    ALL_TARGET_GROUPS.extend([
        expand(f"{RESULTS_DIR}/meaning_module_llm/{{dataset_id}}/{SUBSET_NAME}/bulk_x_features.csv", dataset_id=DATASET_IDS),
        expand(f"{RESULTS_DIR}/meaning_module_llm/{{dataset_id}}/{SUBSET_NAME}/module_annotations.csv", dataset_id=DATASET_IDS),
