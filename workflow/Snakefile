if MODULE_MEANING_GENES_ENABLED:
    ALL_TARGET_GROUPS.extend([
        expand(f"{RESULTS_DIR}/meaning_module_genes/{{dataset_id}}/{SUBSET_NAME}/bulk_x_features.csv", dataset_id=GENE_LIKE_DATASET_IDS),
