if MODULE_SET_ENRICHMENT_ENABLED:
    ALL_TARGET_GROUPS.append(
        expand(
            f"{RESULTS_DIR}/module_set_enrichment/{{dataset_id}}/{SUBSET_NAME}/mhg_enrichment.csv",
            dataset_id=DATASET_IDS
        )
    )

ALL_TARGETS = [path for group in ALL_TARGET_GROUPS for path in group]


rule all:
    input:
        ALL_TARGETS


